# Alembic (garder les migrations versionnées, ignorer les artefacts locaux)
# (les fichiers de migration dans versions/ doivent être commités)

# ─────────────────────────────────────────────────────────────
# Frontend (React + Vite + TypeScript + Tailwind)
# ─────────────────────────────────────────────────────────────
node_modules/
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/.vite/
.vite/
dist/
dist-ssr/
*.tsbuildinfo

# Logs npm / yarn / pnpm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# Cache ESLint / Prettier
.eslintcache
.prettiercache

# ─────────────────────────────────────────────────────────────
# PostgreSQL / pgvector — données persistées (volumes)
# ─────────────────────────────────────────────────────────────
pgdata/
postgres-data/
*.sql.backup
*.dump

# ─────────────────────────────────────────────────────────────
# Documents & uploads (core service) — ne pas versionner les données utilisateurs
# ─────────────────────────────────────────────────────────────
uploads/
storage/
media/
*.upload

# RAG — index vectoriels / embeddings générés localement
embeddings/
vector_store/
*.faiss
*.index

